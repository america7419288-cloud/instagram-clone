<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only network security config.
  Allows cleartext for localhost, emulator (10.0.2.2), and local dev servers.
  This file is ONLY active in debug builds (src/debug/AndroidManifest.xml merges it).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <!-- Allow cleartext only for local dev servers -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.71.245.227</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
    </domain-config>
</network-security-config>
