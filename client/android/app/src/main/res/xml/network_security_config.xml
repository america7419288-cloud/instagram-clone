<?xml version="1.0" encoding="utf-8"?>
<!--
  Production network security config.
  - HTTPS only for all traffic (no cleartext in release)
  - System + user CA certs trusted (for dev convenience)
  - Debug overrides handled in src/debug/res/xml/network_security_config.xml
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
