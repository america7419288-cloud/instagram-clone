# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ─── SECRETS — NEVER COMMIT ─────────────────────────────────────────────
# Release keystore — losing this means you can't update the app on Play Store
android/key.properties
android/upload-keystore.jks
android/*.jks
android/*.keystore

# Environment files — contain server URLs / API keys
.env
.env.local
.env.production

# Debug symbols (large, store separately for crash symbolication)
build/debug-info/
